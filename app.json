{
  "expo": {
    "name": "PreRoll",
    "slug": "preroll",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.preroll.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PreRoll needs the camera to show a preview and record after the countdown.",
        "NSMicrophoneUsageDescription": "PreRoll needs the microphone to record audio with your videos.",
        "NSPhotoLibraryAddUsageDescription": "PreRoll saves your recorded clips to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.preroll.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "PreRoll needs camera access to record after the countdown finishes.",
          "microphonePermission": "PreRoll needs microphone access to record audio with your videos.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "PreRoll saves your clips to your photo library.",
          "savePhotosPermission": "PreRoll saves your recordings to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "43ba2732-d7eb-4afb-b6dc-5605037019c7"
      }
    },
    "owner": "jmridesbikes"
  }
}
